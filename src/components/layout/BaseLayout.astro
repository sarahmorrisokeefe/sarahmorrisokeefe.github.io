---
import '../../styles/global.css';
import Analytics from '@vercel/analytics/astro';
import LightsOut from '../lights-out/LightsOut.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Sarah O'Keefe — Front-End Engineer",
  description = 'Front-end software engineer based in Charlotte, NC. Building things with React and TypeScript at iHeartRadio.',
} = Astro.props;

const gaId = import.meta.env.PUBLIC_GA_ID;
const enableAnalytics = import.meta.env.PROD && gaId;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- Favicon -->
    <link rel="icon" href="/favicon.ico" />

    <!--
      Theme init: runs before first paint to prevent flash of wrong theme.
      Reads localStorage and applies 'dark' class to <html> immediately.
    -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem('theme');
        const prefersDark = window.matchMedia(
          '(prefers-color-scheme: dark)',
        ).matches;
        const theme = stored ?? (prefersDark ? 'dark' : 'light');
        document.documentElement.classList.toggle('dark', theme === 'dark');
      })();
    </script>

    <!-- Google Fonts: Lora (serif headings) + Inter (body) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;1,400&family=Inter:wght@300;400;500;600&family=Press+Start+2P&display=swap"
      rel="stylesheet"
    />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://www.okeefesarah.com" />
    <!--
      TODO: create a 1200×630 social share image and save it to public/og-image.png,
      then uncomment the line below:
    -->
    <!-- <meta property="og:image" content="https://www.okeefesarah.com/og-image.png" /> -->

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Google Analytics 4 (production only, gated by import.meta.env.PROD) -->
    {
      enableAnalytics && (
        <>
          <script
            is:inline
            async
            src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}
          />
          <script is:inline define:vars={{ gaId }}>
            window.dataLayer = window.dataLayer || [];
            function gtag() {
              dataLayer.push(arguments);
            }
            gtag('js', new Date());
            gtag('config', gaId);
          </script>
        </>
      )
    }

    <!-- A little something for anyone curious enough to open dev tools -->
    <script is:inline>
      console.log(
        "%cSarah O'Keefe%c — Front-End Software Engineer%c\n\nHey, nice of you to check under the hood. \u{1F440}\n\n\u{1F3C1} There's a little easter egg tucked in the footer — find the checkered flag and see how fast your reflexes are.\n\nIf you're hiring: I'm open to good opportunities. Either way, glad you stopped by.",
        'color: #5E6C5B; font-weight: 700; font-size: 15px;',
        'color: #849680; font-weight: 400; font-size: 13px;',
        'font-weight: 400; font-size: 13px;',
      );
    </script>
  </head>
  <body>
    <slot />
    <LightsOut />
    <Analytics />
  </body>
</html>
